# --- API ---
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres (Supabase-ready). If UNSET, the API uses an in-memory store and is fully runnable.
# Supabase: copy the "Connection string" (URI) from Project Settings → Database.
DATABASE_URL=

# LLM intent classification. If UNSET, a deterministic keyword classifier is used instead.
ANTHROPIC_API_KEY=
# Fast + cheap model for /intent classification.
INTENT_MODEL=claude-haiku-4-5

