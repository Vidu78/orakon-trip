# --- API ---
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres (Supabase-ready). If UNSET, the API uses an in-memory store and is fully runnable.
# Supabase: copy the "Connection string" (URI) from Project Settings → Database.
DATABASE_URL=

# LLM intent classification. If UNSET, a deterministic keyword classifier is used instead.
ANTHROPIC_API_KEY=
# Fast + cheap model for /intent classification.
INTENT_MODEL=claude-haiku-4-5

# Free key from openchargemap.org for the /chargers endpoint.
# REQUIRED for real results: anonymous requests are rejected (403). Free signup, ~1 min.
OPENCHARGEMAP_API_KEY=

# --- Dashboard (Vite) ---
# URL pubblico dell'API. In locale: http://localhost:4000
# In produzione: l'URL del servizio (es. Render) — impostalo come env su Vercel.
VITE_API_URL=http://localhost:4000
# VITE_API_URL=https://orakon-trip-api.onrender.com
# VITE_TRIP_ID=demo-trip
